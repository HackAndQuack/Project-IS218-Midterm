# Copy this file to .env and adjust as needed. All variables are optional;
# defaults shown below are used if a variable is omitted.

# Base directory for logs/history when not overridden individually.
# Defaults to the project root. Leave commented out to use that default -
# an empty (but set) value here resolves to the current working directory.
# CALCULATOR_BASE_DIR=

# Maximum number of calculations kept in history.
CALCULATOR_MAX_HISTORY_SIZE=1000

# Whether history is auto-saved after each calculation (true/false).
CALCULATOR_AUTO_SAVE=true

# Decimal places used when formatting calculation results.
CALCULATOR_PRECISION=10

# Largest absolute value accepted as input.
CALCULATOR_MAX_INPUT_VALUE=1e999

# Encoding used for file I/O.
CALCULATOR_DEFAULT_ENCODING=utf-8

# Optional overrides for log/history file locations.
# Default to <base_dir>/logs and <base_dir>/history.
# CALCULATOR_LOG_DIR=
# CALCULATOR_LOG_FILE=
# CALCULATOR_HISTORY_DIR=
# CALCULATOR_HISTORY_FILE=
